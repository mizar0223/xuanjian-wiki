# MediaWiki / MariaDB 凭据
# 复制为 .env 并填入真实值（.env 已在 .gitignore 中，不会被提交到 git）
# docker compose 用 env_file 加载，LocalSettings.php 由 deploy-wiki.sh 渲染时读取
#（deploy-wiki.sh 默认从 /opt/mediawiki/.env 读，也可通过 WIKI_DEPLOY_ENV_FILE 改路径）

# ---- MariaDB ----
MYSQL_DATABASE=mediawiki
MYSQL_USER=mediawiki
MYSQL_PASSWORD=<YOUR_DB_PASSWORD>
MYSQL_ROOT_PASSWORD=<YOUR_DB_ROOT_PASSWORD>

# ---- MediaWiki 应用 ----
MW_ADMIN_USER=LeoAdmin
MW_ADMIN_PASS=<YOUR_ADMIN_PASSWORD>

# ---- MediaWiki 加密配置（deploy-wiki.sh 渲染 LocalSettings.php 用）----
# Session token 签名密钥（关键！泄露=任意账户接管）
# 推荐 64 位十六进制：openssl rand -hex 32
MW_SECRET_KEY=<64位十六进制字符串>
# 升级密钥
# 推荐 16 位十六进制：openssl rand -hex 8
MW_UPGRADE_KEY=<16位十六进制字符串>
